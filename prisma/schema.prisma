generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = "postgresql://dummy:dummy@localhost:5432/dummy"
}

enum Role {
  USER
  BROKER
  ADMIN
}

enum PropertyType {
  OFFICE
  RETAIL
  INDUSTRIAL
  MULTIFAMILY
  LAND
  WAREHOUSE
  SPECIAL_PURPOSE
}

enum ListingType {
  FOR_SALE
  FOR_LEASE
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String?
  role          Role      @default(USER)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts         Account[]
  sessions         Session[]
  properties       Property[]      @relation("SubmittedProperties")
  savedProperties  SavedProperty[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Property {
  id               String       @id @default(cuid())
  title            String
  description      String       @db.Text
  propertyType     PropertyType
  listingType      ListingType
  price            Float
  capRate          Float?
  noi              Float?
  sqft             Float?
  lotSizeAcres     Float?
  yearBuilt        Int?
  occupancy        Float?
  
  // Location
  streetAddress    String
  city             String
  state            String
  zipCode          String
  lat              Float?
  lng              Float?

  // Flags & Meta
  isApproved       Boolean      @default(false)
  isFeatured       Boolean      @default(false)
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  // Relations
  submitterId      String
  submitter        User         @relation("SubmittedProperties", fields: [submitterId], references: [id])
  
  images           PropertyImage[]
  analytics        PropertyAnalytics?
  savedBy          SavedProperty[]
}

model PropertyImage {
  id         String   @id @default(cuid())
  url        String
  publicId   String?  // For Cloudinary
  propertyId String
  order      Int      @default(0)
  createdAt  DateTime @default(now())
  
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
}

model PropertyAnalytics {
  id                 String   @id @default(cuid())
  propertyId         String   @unique
  
  // Intelligence Scores (1-100)
  roiScore           Int?
  constructionScore  Int?
  lifestyleScore     Int?
  dealScore          Int?
  
  // Traffic / Views
  pageViews          Int      @default(0)
  searchAppearances  Int      @default(0)
  
  // Market Indicators
  areaGrowthSignal   String?  // High, Stable, Declining
  
  updatedAt          DateTime @updatedAt
  property           Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
}

model SavedProperty {
  id         String   @id @default(cuid())
  userId     String
  propertyId String
  createdAt  DateTime @default(now())

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@unique([userId, propertyId])
}
